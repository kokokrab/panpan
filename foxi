# ===== SELECT GROUP (INTERACTIVE) =====

while true; do
  echo "Select a group to run:"
  echo "1) $GROUP_1_NAME"
  echo "2) $GROUP_2_NAME"
  echo "3) $GROUP_3_NAME"
  echo "4) $GROUP_4_NAME"
  echo "5) $GROUP_5_NAME"
  echo "6) $GROUP_6_NAME"
  echo "7) $GROUP_7_NAME"
  echo "8) $GROUP_8_NAME"

  read -p "Enter group number (1-8): " ACTIVE_GROUP

  if [[ "$ACTIVE_GROUP" =~ ^[1-8]$ ]]; then
    break
  else
    echo "Invalid input. Try again."
  fi
done

# ===== VALIDATION =====

GROUP_NAME_VAR="GROUP_${ACTIVE_GROUP}_NAME"
GROUP_SERVERS_VAR="GROUP_${ACTIVE_GROUP}_SERVERS"

if [ -z "${!GROUP_NAME_VAR}" ]; then
  echo "Invalid ACTIVE_GROUP ($ACTIVE_GROUP). Defaulting to Group 1."
  ACTIVE_GROUP=1
  GROUP_NAME_VAR="GROUP_1_NAME"
  GROUP_SERVERS_VAR="GROUP_1_SERVERS"
fi

# ===== LOAD SELECTED GROUP =====

GROUP_NAME="${!GROUP_NAME_VAR}"
servers_raw="${!GROUP_SERVERS_VAR}"

readarray -t servers < <(printf "%s\n" "$servers_raw" | sed '/^\s*$/d')

# ===== WEBHOOK FUNCTION =====

send_webhook() {
  local message="$1"

  curl --max-time 5 -H "Content-Type: application/json" \
  -X POST \
  -d "$(printf '{"content":"%s"}' "$message")" \
  "$WEBHOOK_URL" > /dev/null 2>&1
}

total=${#servers[@]}

echo "Loaded $total servers from [$GROUP_NAME]"
send_webhook "**[$GROUP_NAME]** 🚀 Started with $total servers"

# ===== MAIN LOOP =====

while true; do
  index=1
  for server in "${servers[@]}"; do
    echo "Switching to ($index/$total)"
    echo "DEBUG: $server"

    send_webhook "**[$GROUP_NAME]** 🔄 Switching server **($index/$total)**"

    am start -a android.intent.action.MAIN -c android.intent.category.HOME
    sleep 2

    MAX_RETRIES=3
    joined=false

    for ((i=1; i<=MAX_RETRIES; i++)); do
      echo "Attempt $i to join server"

      am start -a android.intent.action.VIEW -d "$server"
      sleep 8

      current_app=$(dumpsys window | grep -E 'mCurrentFocus')

      if echo "$current_app" | grep -qi "roblox"; then
        echo "Roblox detected ✅"
        joined=true
        break
      else
        echo "Join failed ❌ retrying..."
        sleep 3
      fi
    done

    if [ "$joined" = true ]; then
      send_webhook "**[$GROUP_NAME]** ✅ Joined server **($index/$total)**"
    else
      send_webhook "**[$GROUP_NAME]** ❌ Failed to join server **($index/$total)**"
    fi

    sleep 720
    index=$((index+1))
  done
done
